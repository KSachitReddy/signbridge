{
  "name": "signbridge-ai",
  "private": true,
  "version": "0.0.0",
  "description": "SignBridge - AI-powered accessibility platform bridging deaf, hard-of-hearing, and hearing individuals via real-time sign language recognition and translation.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "biome": "node scripts/biome.cjs check .",
    "oxlint": "oxlint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "typecheck": "tsc --noEmit",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "@testing-library/dom": "^10.4.1",
    "i18next": "^24.2.2",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^15.4.0",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.0.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.0.11",
    "jsdom": "^26.0.0",
    "knip": "^5.12.0",
    "oxlint": "^1.69.0",
    "postcss": "^8.5.15",
    "prettier": "^3.2.5",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vercel": "^54.13.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
