{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "experimentalServices": {
    "signbridge-backend": {
      "type": "web",
      "routePrefix": "/",
      "framework": "vite",
      "buildCommand": "pip install -r backend/requirements.txt"
    },
    "signbridge-frontend": {
      "type": "web",
      "routePrefix": "/_/signbridge-frontend",
      "framework": "vite",
      "buildCommand": "cd frontend && npm install && npm run build"
    }
  }
}
