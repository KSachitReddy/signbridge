{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "experimentalServices": {
    "signbridge-backend": {
      "type": "web",
      "routePrefix": "/api",
      "framework": "vite",
      "buildCommand": "mkdir -p dist && echo noop > dist/index.html"
    },
    "signbridge-frontend": {
      "type": "web",
      "routePrefix": "/",
      "framework": "vite",
      "buildCommand": "npm run build"
    }
  }
}
